# ──────────────────────────────────────────────────────────────────────────────
# OMEGA AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Google OAuth (NextAuth) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-strong-random-secret

# ── Admin Bypass (DEVELOPMENT ONLY) ──────────────────────────────────────────
# Set to true to skip auth for /admin routes without logging in.
# WARNING: Set to false or remove entirely before deploying to production!
ADMIN_BYPASS=true

# ── AI Engine ─────────────────────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:4000
AI_ENGINE_API_KEY=generate-a-strong-random-key

# ── Encoder Service (for semantic text + multimodal) ───────────────────────────
# Run: cd services/harvesters && uvicorn encoder_service:app --port 5001
ENCODER_SERVICE_URL=http://localhost:5001

# ── Multimodal weights (text, image, video, audio) ───────────────────────────
# OMEGA_MULTIMODAL_WEIGHTS={"text":0.4,"image":0.2,"video":0.2,"audio":0.2}

# ── gX-Li-Ω Training Parameters ───────────────────────────────────────────────
LEARNING_RATE=0.001
MIRROR_SYNC_RATE=0.95
LI_GROWTH_RATE=0.1
LI_MERGE_THRESHOLD=0.85
OMEGA_CONVERGENCE_THRESHOLD=0.95
OMEGA_MAX_ITERATIONS=10
OMEGA_SELF_VALIDATION_DEPTH=3
NEURON_DENSITY=128
LAYER_DEPTH=6
LI_CORE_COUNT=8
MIRROR_DIVERGENCE_TOLERANCE=0.15
CROSS_NETWORK_TRANSFER=0.3
BATCH_SIZE=32
WARMUP_STEPS=500
DROPOUT_RATE=0.1
REGULARIZATION_STRENGTH=0.0001
MOMENTUM=0.9
WEIGHT_DECAY=0.01
MEMORY_CONSOLIDATION_CYCLE=1000
CACHE_SIZE=10000
ENTROPY_REGULATION=0.5
PATTERN_SENSITIVITY=0.3
ANOMALY_DETECTION_THRESHOLD=0.85
TRUTH_CONFIDENCE_THRESHOLD=0.75
LI_PARTICIPATION_MIN=2
MIRROR_AGREEMENT_REQUIRED=true

# ── Harvesters ────────────────────────────────────────────────────────────────
HARVESTER_URL=http://localhost:8000
HARVEST_INTERVAL=3600
MAX_WORKERS=4
DATA_QUALITY_THRESHOLD=0.7
DEDUPLICATION_THRESHOLD=0.92

# ── Render deploy ─────────────────────────────────────────────────────────────
# render.yaml в корне — Blueprint для omega-ai-engine + omega-harvesters.
# Vercel (apps/web): AI_ENGINE_URL, HARVESTER_URL — URL сервисов на Render.
# Harvesters: AI_ENGINE_URL — URL AI Engine (задать после деплоя).
# HF_TOKEN — для gated Hugging Face датасетов (опционально).
